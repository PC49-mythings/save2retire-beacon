# ─── Beacon Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to source control.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# ─── Database ─────────────────────────────────────────────────────────────────
# Shares the same PostgreSQL instance as save2retire.
# Beacon uses the 'beacon' schema; S2R views are in the 'public' schema.
# The DB user must have:
#   - READ/WRITE on beacon.* (all beacon tables)
#   - SELECT on public.v_beacon_* (the read-only views defined in 002_s2r_views.sql)
DATABASE_URL=postgresql://save2retire:s2r_local_2026@localhost:5432/save2retire

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Beacon has its own JWT secret — completely separate from save2retire's.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
BEACON_JWT_SECRET=76c22890634e237472f2edd21349676bf6653c1d455dd9d114f91d6cf04e1e67627220e7cac9100b0791067844365f2c49082145e49cb6290790222b7809aabc
BEACON_JWT_EXPIRY=8h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production: https://insights.save2retire.ai
# In development: http://localhost:5174 (Vite default, change if needed)
CORS_ORIGIN=http://localhost:5174

# ─── Platform Owner ───────────────────────────────────────────────────────────
# Used by seed script to create the initial platform_owner account.
# Change these before seeding production.
SEED_OWNER_EMAIL=admin@save2retire.ai
SEED_OWNER_NAME=Beacon Admin
SEED_OWNER_PASSWORD=changeme_before_prod

# ─── Email (SES — optional in dev, required in prod) ─────────────────────────
# Uses the same SES setup as save2retire if available.
SES_REGION=ap-southeast-2
SES_FROM_EMAIL=noreply@save2retire.ai
# Leave blank to skip email in development (password reset codes printed to console)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─── Deployment ───────────────────────────────────────────────────────────────
# The public URL for invite links and email callbacks
APP_URL=http://localhost:5174
